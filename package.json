{
  "name": "nwa-ads-tests",
  "version": "1.0.0",
  "description": "Test harness for nwa-ads.com",
  "private": true,
  "scripts": {
    "test": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:live": "TEST_URL=https://nwa-ads.com playwright test",
    "test:all": "npm test && npm run test:e2e",
    "test:report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "http-server": "^14.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.109.0"
  }
}
